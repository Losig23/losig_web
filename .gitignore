# Unity Addressables and local package artifacts
Assets/AddressableAssetsData/*/*.bin*

# Keep source assets and project settings tracked.
# Commit: Assets/, Packages/, ProjectSettings/
# Do not commit: Library/, Temp/, Logs/, UserSettings/, Builds/
